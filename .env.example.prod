# oCMS Production Environment Example
# Copy to .env and replace placeholder values before deployment.

# REQUIRED: Session encryption secret (minimum 32 bytes)
# Generate with: openssl rand -base64 32
OCMS_SESSION_SECRET=replace-with-strong-random-secret

# REQUIRED: Server configuration
OCMS_SERVER_HOST=127.0.0.1
OCMS_SERVER_PORT=8082
OCMS_ENV=production
OCMS_LOG_LEVEL=warn

# REQUIRED: Keep seeding disabled in production
OCMS_DO_SEED=false

# REQUIRED: Database path (relative to WorkingDirectory)
OCMS_DB_PATH=./data/ocms.db

# REQUIRED: Theme configuration
# Core themes (default, developer) are embedded in the binary.
# Custom themes go in the custom/themes/ directory to override or extend core themes.
OCMS_CUSTOM_DIR=./custom
OCMS_ACTIVE_THEME=developer

# REQUIRED for GEOIP-enabled analytics in production
OCMS_GEOIP_DB_PATH=/var/local/geoip/GeoLite2-Country.mmdb

# REQUIRED for embed proxy in production when embed provider is enabled.
# Origin matching is exact (scheme + host). Include every public hostname
# that can serve chat (for example apex and www domains).
OCMS_EMBED_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# REQUIRED for embed proxy in production when embed provider is enabled.
# Use api.dify.ai for hosted Dify, or replace with your self-hosted API host.
OCMS_EMBED_ALLOWED_UPSTREAM_HOSTS=api.dify.ai

# Hardened policy for production embed proxy.
OCMS_REQUIRE_EMBED_ALLOWED_ORIGINS=true
OCMS_REQUIRE_EMBED_ALLOWED_UPSTREAM_HOSTS=true

# REQUIRED in production by embed module initialization.
# Generate with: openssl rand -base64 32
OCMS_EMBED_PROXY_TOKEN=replace-with-embed-proxy-token

# Optional: Redis for distributed caching
# OCMS_REDIS_URL=redis://localhost:6379/0

# Optional: hCaptcha for bot protection
# OCMS_HCAPTCHA_SITE_KEY=your-site-key
# OCMS_HCAPTCHA_SECRET_KEY=your-secret-key
